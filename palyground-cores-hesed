                textHex: "#1F2A23"
            },
            papiro: {
                name: "Papiro e Ébano",
                bg: "#FAF8F4",
                text: "#1A1A1A",
                support: "#72706D", // Pedra
                accent: "#B58A59", // Latão/Bronze
                bgHex: "Papiro Claro (#FAF8F4)",
                accentLabel: "Latão Escovado",
                promptColors: "ancient papyrus paper texture, dark ebony charcoal values, warm brass and vintage bronze details, architectural clean lines, sophisticated lighting",
                textHex: "#1A1A1A"
            }
        };

        // Estado do Aplicativo
        let currentPaletteKey = 'linho';
        const apiKey = ""; // A chave é fornecida pelo runtime automaticamente

        // Presets de Prompts para o Gerador
        const prompts = {
            casal: "A candid spontaneous photograph of an attractive Christian couple in their early 30s having a deep warm conversation inside a beautiful minimalist boutique coffee shop. Natural soft volumetric lighting, shot on 35mm lens, highly detailed faces, looking happy and genuine, color-graded to match: ",
            mulher: "A beautiful natural candid lifestyle portrait of a 29-year-old Brazilian Christian woman, looking at the camera with a gentle warm smile, holding a ceramic coffee cup in a sunny park with soft blurred foliage in the background, elegant, authentic, color-graded to match: ",
            homem: "A professional authentic lifestyle portrait of a 33-year-old Christian man with a warm friendly smile, sitting in a cozy study room with a bookcase of theological books behind him, soft ambient lighting, style of design magazine, color-graded to match: ",
            leitura: "An elegant editorial macro flatlay photograph of an open physical bible, a warm cup of coffee with latte art on a rustic wooden table, with natural warm sunlight casting soft shadows, peaceful and quiet devotions vibe, color-graded to match: "
        };

        // Aplica a Paleta no Celular do Simulador
        function applyPalette(key) {
            currentPaletteKey = key;
            const p = palettes[key];

            // 1. Alterna estado ativo dos botões no painel esquerdo
            document.querySelectorAll('[id^="btn-"]').forEach(btn => {
                btn.className = "w-full flex items-center justify-between p-3.5 rounded-2xl border bg-slate-900/40 hover:bg-slate-900/80 transition text-left border-slate-800";
            });
            document.getElementById(`btn-${key}`).className = "w-full flex items-center justify-between p-3.5 rounded-2xl border bg-slate-900/80 transition text-left border-emerald-500/50 shadow-md shadow-emerald-900/10";

            document.querySelectorAll('[id^="check-"]').forEach(el => el.classList.add('hidden'));
            document.getElementById(`check-${key}`).classList.remove('hidden');

            // 2. Aplica as cores de fundo e texto no celular
            const appScreen = document.getElementById('app-screen');
            appScreen.style.backgroundColor = p.bg;

            const appBrand = document.getElementById('app-brand');
            appBrand.style.color = p.text;

            // 3. Atualiza as tags do perfil
            document.querySelectorAll('.app-tag').forEach(tag => {
                tag.style.backgroundColor = p.bg;
                tag.style.borderColor = p.support;
                tag.style.color = p.text;
            });

            // 4. Atualiza os botões e detalhes em destaque (Accent)
            document.getElementById('badge-verified').style.backgroundColor = p.accent;
            document.getElementById('match-percent').style.backgroundColor = p.accent;
            document.getElementById('testimony-text').style.borderColor = p.accent;
            document.getElementById('btn-interest').style.backgroundColor = p.accent;

            // 5. Atualiza as sub-tags (interesses) com opacidade suave
            document.querySelectorAll('.app-subtag').forEach(subtag => {
                subtag.style.backgroundColor = `${p.accent}15`; // 15 em hex para opacidade suave
                subtag.style.color = p.accent;
            });

            // 6. Altera a cor padrão do photo-container (gradiente de fundo)
            const photoContainer = document.getElementById('photo-container');
            if (!photoContainer.dataset.hasImage) {
                photoContainer.style.backgroundImage = `linear-gradient(135deg, ${p.bg} 0%, ${p.support} 100%)`;
            }

            // 7. Atualiza o indicador textual da regra de injeção de cores no painel
            document.getElementById('color-rule-hint').innerHTML = `✨ A paleta <b>${p.name}</b> será injetada para garantir a harmonia cromática nas fotos!`;
        }

        // Seleciona um Preset e escreve no input do Prompt
        function selectPreset(type) {
            const p = palettes[currentPaletteKey];
            const basePrompt = prompts[type];
            document.getElementById('prompt-input').value = basePrompt + p.promptColors;
        }

        // Executa Chamada com Retries e Backoff Exponencial
        async function fetchWithRetry(url, options, retries = 5, delay = 1000) {
            try {
                const response = await fetch(url, options);
                if (!response.ok) {
                    const errText = await response.text();
                    throw new Error(`HTTP error! status: ${response.status} - ${errText}`);
                }
                return await response.json();
            } catch (error) {
                if (retries > 0) {
                    await new Promise(resolve => setTimeout(resolve, delay));
                    return fetchWithRetry(url, options, retries - 1, delay * 2);
                }
                throw error;
            }
        }

        // Função Principal de Geração de Imagem via Imagen 4.0
        async function generateAIImage() {
            const promptText = document.getElementById('prompt-input').value.trim();
            const btnGenerate = document.getElementById('btn-generate');
            const errorBox = document.getElementById('error-box');
            const loadingSpinner = document.getElementById('loading-spinner');
            const photoPlaceholder = document.getElementById('photo-placeholder');
            const photoContainer = document.getElementById('photo-container');

            if (!promptText) {
                errorBox.innerText = "Por favor, digite uma descrição ou selecione um preset de estilo ao lado.";
                errorBox.classList.remove('hidden');
                return;
            }

            // Ativa o Loading State
            errorBox.classList.add('hidden');
            loadingSpinner.classList.remove('hidden');
            btnGenerate.disabled = true;
            document.getElementById('btn-icon').innerText = "⏳";
            document.getElementById('btn-text').innerText = "Gerando Imagem...";

            // Configuração do Endpoint de Imagem (Imagen 4.0 - predict)
            const url = `https://generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict?key=${apiKey}`;

            const payload = {
                instances: [
                    { prompt: promptText }
                ],
                parameters: {
                    sampleCount: 1,
                    aspectRatio: "1:1" // Formato quadrado do card do app
                }
            };

            try {
                const result = await fetchWithRetry(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                // Valida resposta da API
                if (result.predictions && result.predictions[0] && result.predictions[0].bytesBase64Encoded) {
                    const base64Data = result.predictions[0].bytesBase64Encoded;
                    const imageUrl = `data:image/png;base64,${base64Data}`;

                    // Aplica a imagem de IA gerada no container
                    photoContainer.style.backgroundImage = `url(${imageUrl})`;
                    photoContainer.dataset.hasImage = "true";
                    photoPlaceholder.classList.add('hidden');
                } else {
                    throw new Error("Formato de resposta inesperado da API de geração de imagens.");
                }

            } catch (error) {
                console.error(error);
                errorBox.innerText = `Ocorreu um erro técnico: não foi possível gerar a imagem de inteligência artificial. Verifique se a chave de API está configurada. Detalhes: ${error.message}`;
                errorBox.classList.remove('hidden');
            } finally {
                // Remove o Loading State
                loadingSpinner.classList.add('hidden');
                btnGenerate.disabled = false;
                document.getElementById('btn-icon').innerText = "⚡";
                document.getElementById('btn-text').innerText = "Gerar Foto de Perfil com IA";
            }
        }

        // Inicialização com a Paleta Linho padrão e preenchimento de prompt sugerido
        window.onload = function() {
            applyPalette('linho');
            selectPreset('casal');
        };
    </script>
</body>
</html>

